# Development environment — copy to .env.development and fill in your dev Supabase project credentials
# EAS Build automatically loads this file for the 'development' profile

# App variant — controls the environment badge and app behaviour
EXPO_PUBLIC_APP_VARIANT=development

# Supabase (get from your dev Supabase project → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-here

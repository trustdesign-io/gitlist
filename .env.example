# Base environment — copy to .env for local development
# For per-environment builds, use .env.development / .env.staging / .env.production
# (see docs/SETUP.md for environment management instructions)

# App variant — controls the environment badge shown in dev/staging builds
# Values: development | staging | production
EXPO_PUBLIC_APP_VARIANT=development

# Supabase (get from Supabase dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry (get from Sentry dashboard → Project → Settings → Client Keys)
# Leave blank to disable error reporting (app runs normally without it)
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/YOUR_PROJECT_ID

# RevenueCat (get from app.revenuecat.com → Project → API Keys → Public iOS API Key)
# Leave blank to disable in-app purchases (requires dev build — not Expo Go compatible)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_key_here

# Legal URLs (must be live before App Store submission)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
EXPO_PUBLIC_TERMS_URL=https://yourdomain.com/terms

# Apple credentials for EAS Submit (production only — do not commit real values)
# APPLE_ID: the Apple ID email used to sign in to App Store Connect
# ASC_APP_ID: the numeric App Store Connect app ID (from App Store Connect → App → App Information)
# APPLE_TEAM_ID: the 10-character Apple Team ID (from developer.apple.com → Membership)
APPLE_ID=your@apple.com
ASC_APP_ID=1234567890
APPLE_TEAM_ID=XXXXXXXXXX

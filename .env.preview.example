# Staging environment — copy to .env.preview and fill in your staging Supabase project credentials
# EAS Build automatically loads this file for the 'preview' profile

# App variant — controls the environment badge and app behaviour
EXPO_PUBLIC_APP_VARIANT=staging

# Supabase (get from your staging Supabase project → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key-here

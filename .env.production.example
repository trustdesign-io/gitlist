# Production environment — copy to .env.production and fill in your production Supabase project credentials
# EAS Build automatically loads this file for the 'production' profile

# App variant — no badge shown in production builds
EXPO_PUBLIC_APP_VARIANT=production

# Supabase (get from your production Supabase project → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROD_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-prod-anon-key-here
